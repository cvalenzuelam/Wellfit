      "name": "Get Token Details",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Response body is a valid JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "let responseJson = pm.response.json();\r",
              "\r",
              "pm.test(\"Response object exists\", function () {\r",
              "    pm.expect(responseJson).to.have.property('response');\r",
              "});\r",
              "\r",
              "pm.test(\"response.processorToken exists\", function () {\r",
              "    pm.expect(responseJson.response).to.have.property('processorToken');\r",
