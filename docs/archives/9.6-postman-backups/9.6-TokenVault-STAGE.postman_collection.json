              "mode": "raw",
              "raw": "SELECT Id, TransactionId, Amount, PaymentTypeMethod, OrderId, TimeStamp\nFROM [Payments].[Payments]\nWHERE TransactionId = '{{lastTransactionId}}';\n-- Expect PaymentTypeMethod = 1",
