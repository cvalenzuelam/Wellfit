    {
      "name": "TC04. Ensure, Token is not saved into tokenvalut DB when CNP V1 endpoint runs with processor token",
      "description": "Case 167992. Baseline query \u2192 process-card \u2192 query unchanged.",
      "item": [
        {
          "name": "GET query \u2014 baseline by processorToken",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{Payment-Bearer-Token}}"
              }
            ],
            "url": "{{TokenVaultAPI}}/query?processorToken={{tokenVisa}}",
            "description": "Save baseline response text."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 2xx/404 ok as baseline', () => pm.expect(pm.response.code).to.be.below(500));",
                  "pm.environment.set('tvQueryBaseline', pm.response.text());",
                  "console.log('baseline len=' + pm.response.text().length);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST process-card \u2014 processor token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{Payment-Bearer-Token}}"
              }
            ],
            "url": "{{URL}}/credit-card/process-card",
            "description": "Charge with same processor token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 11.04,\n  \"expirationDate\": \"{{expirationDate}}\",\n  \"network\": \"VI\",\n  \"orderId\": \"{{orderId}}\",\n  \"payFacFee\": 0,\n  \"subMerchantId\": \"{{subMerchantId}}\",\n  \"token\": \"{{tokenVisa}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const orderId = 'R96-TC04-' + Date.now().toString().slice(-10);",
                  "pm.environment.set('orderId', orderId);",
                  "console.log('orderId=' + orderId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const txn = j.transactionId || j.TransactionId || (j.response && j.response.transactionId);",
                  "pm.test('transactionId present', () => pm.expect(txn).to.be.ok);",
                  "pm.environment.set('lastTransactionId', String(txn));",
                  "console.log('lastTransactionId=' + txn);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET query \u2014 after charge (compare baseline)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{Payment-Bearer-Token}}"
              }
            ],
            "url": "{{TokenVaultAPI}}/query?processorToken={{tokenVisa}}",
            "description": "Compare to baseline \u2014 expect no new vault write from V1 CNP."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const after = pm.response.text();",
                  "const before = pm.environment.get('tvQueryBaseline') || '';",
                  "console.log('before', before.substring(0, 300));",
                  "console.log('after', after.substring(0, 300));",
                  "pm.test('HTTP below 500', () => pm.expect(pm.response.code).to.be.below(500));",
                  "pm.test('No new vault persist from CNP V1 (body unchanged or still empty)', () => {",
                  "  // Allow identical; if both empty/404-like, pass",
                  "  pm.expect(after).to.eql(before);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "TC05\u2013TC07 + TC13. CP charge-card (PARKED \u2014 needs QA lead support)",
      "description": "Cases 167993, 167994, 167995, 168013.\n\n**NOTE:** Needs **QA lead support** (STAGE physical lane / terminal that returns `cardToken`). Simulator laneId 9999 is not enough for TokenVault ACs.\nKeep these requests; do not delete. Run when lead is available.\n",
      "item": [
        {
          "name": "POST charge-card \u2014 PARKED placeholder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{Payment-Bearer-Token}}"
              }
            ],
            "url": "{{URL}}/credit-card-present/charge-card",
            "description": "PARKED until QA lead provides STAGE CP lane + terminal.\nFill {{cpSubMerchantId}} / {{cpLaneId}} when available.\nSimulator 9999: may Approve but often no cardToken \u2014 not enough for TokenVault ACs.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1.0,\n  \"orderId\": \"{{orderId}}\",\n  \"payFacFee\": 0,\n  \"subMerchantId\": \"{{cpSubMerchantId}}\",\n  \"laneId\": \"{{cpLaneId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const orderId = 'R96-CP-' + Date.now().toString().slice(-10);",
                  "pm.environment.set('orderId', orderId);",
                  "console.log('orderId=' + orderId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "console.log(pm.response.code + ' ' + pm.response.text().substring(0, 800));",
                  "pm.test('PARKED \u2014 document result; require physical lane for cardToken', () => {",
                  "  console.warn('CP cases need physical terminal');",
                  "  pm.expect(true).to.be.true;",
                  "});",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const ct = j.cardToken || j.CardToken;",
                  "  if (ct) { pm.environment.set('wellfitTokenGuid', String(ct)); console.log('cardToken=' + ct); }",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "TC08. Ensure, Token is able to add successfully and able to save into token valut DB when tokenVaultAPI/add-token end point runs",
      "description": "Case 167997 \u2014 Testmo Description/Expected/Steps were EMPTY in export.\nScaffolded from TokenVault API collection: POST /add-token \u2192 GET get-token-details \u2192 optional SQL TokenVault.dbo.PaymentTokens.",
      "item": [
        {
          "name": "POST add-token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{Payment-Bearer-Token}}"
              }
            ],
            "url": "{{TokenVaultAPI}}/add-token",
            "description": "Expect 2xx + GUID id persisted.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{$guid}}\",\n  \"processorToken\": \"{{tokenVisa}}\",\n  \"cardLastFour\": \"{{cardLastFourVisa}}\",\n  \"cardBrand\": \"VISA\",\n  \"cardExpirationMonth\": 12,\n  \"cardExpirationYear\": 2034,\n  \"cardZipCode\": \"01803\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
