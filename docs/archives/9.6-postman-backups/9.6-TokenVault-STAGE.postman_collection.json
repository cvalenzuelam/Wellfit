                "type": "text/javascript",
                "exec": [
                  "const orderId = 'R96-GUID-' + Date.now().toString().slice(-10);",
                  "pm.environment.set('orderId', orderId);",
                  "console.log('orderId=' + orderId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const txn = j.transactionId || j.TransactionId || (j.response && j.response.transactionId);",
                  "pm.test('transactionId present', () => pm.expect(txn).to.be.ok);",
                  "pm.environment.set('lastTransactionId', String(txn));",
                  "console.log('lastTransactionId=' + txn);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "TC03. Ensure, CNP V1 endpoint is able to make a sucessful payment with paypageID",
      "description": "Case 167996. eProtect \u2192 process-card payPageRegistrationId. PaymentTypeMethod=1.\nConfluence Visa 4457010000000009 / 349 / 01803.",
      "item": [
        {
          "name": "POST eProtect paypage \u2014 VISA",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "Host",
                "value": "request.eprotect.vantivprelive.com"
              }
            ],
            "url": "https://request.eprotect.vantivprelive.com/eProtect/paypage",
            "description": "Confluence Visa approved PAN.",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "paypageId",
                  "value": "{{paypageId}}",
                  "type": "text"
                },
                {
                  "key": "reportGroup",
                  "value": "Default",
                  "type": "text"
                },
                {
                  "key": "orderId",
                  "value": "TestOrder.TV.TC03",
                  "type": "text"
                },
                {
                  "key": "id",
                  "value": "1111111111222222222222222",
                  "type": "text"
                },
                {
                  "key": "accountNumber",
                  "value": "4457010000000009",
                  "type": "text"
                },
                {
                  "key": "cvv",
                  "value": "349",
                  "type": "text"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "pm.test('not 889', () => pm.expect(String(j.response||'')).to.not.eql('889'));",
                  "pm.test('paypageRegistrationId', () => pm.expect(j.paypageRegistrationId).to.be.ok);",
                  "pm.environment.set('paypageRegistrationId', j.paypageRegistrationId);"
