STAGE_TOKENVAULT_URL=https://stage-platform.wellfit.com/tokenvault
STAGE_TREASURY_URL=https://stage-platform.wellfit.com/treasury
STAGE_WALLET_URL=https://stage-platform.wellfit.com/wallet
STAGE_MP_URL=https://stage-wf-merchantprovisioning-api.azurewebsites.net

